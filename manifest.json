{
  "manifest_version": 3,
  "name": "ClipAsk AI",
  "version": "1.1.1",
  "description": "Highlight or crop anything and ask AI instantly!",
  "permissions": ["contextMenus", "storage", "scripting", "activeTab", "tabs"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["summary.txt", "marked.umd.js", "purify.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}